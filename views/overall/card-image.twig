{#class for animate: show or move#}
<div class="cardImage {% if image.class %}{{ image.class }}{% endif %}">
    {% if image.src %}
    <img src="{{ image.src }}" alt="{{ image.title }}" aria-hidden="true">
    {% endif %}

    {% if image.layers %}
    {% for item in image.layers %}
    <img src="{{ item.layer }}"
         class="{% if image.animation %}{{image.animation}}{% endif %}__{{loop.index}}"
         alt="{{ image.title }}" aria-hidden="true"/>
    {% endfor %}
    {% endif %}
</div>
