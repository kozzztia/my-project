{% extends "overall/base.twig" %}

{% block base %}

    {% set blocks = [
        {'name': 'single-animation',
            'fields': {
            'style': '',
            'class': 'tracker down',
            'image': {'title': '404', 'animation': 'error',
                'class': 'error__image ',
                'layers' : [
                    {'layer': svg_folder ~'animation/404-1.svg'},
                    {'layer': svg_folder ~'animation/404-2.svg'},
                    {'layer': svg_folder ~'animation/404-3.svg'},
                    {'layer': svg_folder ~'animation/404-4.svg'},
                    {'layer': svg_folder ~'animation/404-5.svg'},
                ]}
            },
        },
    ] %}

    {% for block in blocks %}
        {% include 'blocks/main/' ~ block.name ~ '.twig' with
            {
                'block_group': 'main',
                'block_name': block.name,
                'fields': block.fields,
            } %}
    {% endfor %}

{% endblock %}
