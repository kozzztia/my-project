{% extends "overall/base.twig" %}

{% block base %}

    {% set blocks = [
        {'name': 'error',
            'fields': {
            'style': 'text-align: center; margin-bottom: var(--primary-size)',
            'class': 'tracker down',
            },
        },

    ] %}

    {% for block in blocks %}
        {% include 'blocks/main/' ~ block.name ~ '.twig' with
            {
                'block_group': 'main',
                'block_name': block.name,
                'fields': block.fields,
            } %}
    {% endfor %}

{% endblock %}
